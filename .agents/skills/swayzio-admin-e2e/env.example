# swayzio-admin-e2e — copy to ../../../.e2e/env (gitignored) and fill in.
# Source with: set -a; source .e2e/env; set +a   — never commit or print real values.

# --- secrets ---
BROWSER_USE_API_KEY=          # Browser Use cloud API key (persistent browser profile)
AGENTMAIL_API_KEY=            # AgentMail API key (receives Clerk codes at the QA inbox)
SWAYZIO_E2E_CLERK_USER_ID=    # Clerk user id of the QA founder account (role=founder)
SWAYZIO_E2E_PROD_INSTANCE_ID= # Clerk production instance id (ins_...)
SWAYZIO_E2E_BROWSER_PROFILE_ID= # Browser Use persistent profile id (if already created)

# --- non-secret config ---
SWAYZIO_E2E_APP_URL=https://admin.swayzio.com
SWAYZIO_E2E_INBOX_ID=swayzio-qa@agentmail.to
