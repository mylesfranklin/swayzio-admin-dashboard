# Swayzio Admin Dashboard — environment variables
# Copy to .env and fill in. Never commit .env. See docs/ARCHITECTURE.md → Environment.

# Database (Neon Postgres)
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# HubSpot — private-app token (replaces the old Replit connector auth)
HUBSPOT_ACCESS_TOKEN=

# Kit (newsletter) & Mercury (banking)
KIT_API_KEY=
MERCURY_API_KEY=

# Clerk (founders-only auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Comma-separated founder allowlist (lowercase emails)
FOUNDER_EMAILS=myles@swayzio.com
# Clerk redirect targets (sign-in is the only public auth route)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Vercel Cron — bearer secret guarding /api/cron/refresh
CRON_SECRET=

# AI agent (eve.dev) — later phase
ANTHROPIC_API_KEY=

# Swayzio-Core app DB (Neon, read-only role dashboard_ro) — for real track-upload analytics
SWAYZIO_APP_DATABASE_URL=

# Swayzio OS — the agent-native company brain (dedicated Neon project, PG18). See docs/COMPANY-OS.md.
# Pooled connection string. Used by scripts/os-migrate.ts and src/server/os/*. Not yet provisioned.
SWAYZIO_OS_DATABASE_URL=
# F3 boundary: the os_agent_ro read-only role (SELECT on api.*, EXECUTE memory.recall only).
# The agent prefers this over the owner URL — see agent/lib/os.ts.
SWAYZIO_OS_AGENT_RO_URL=

# eve agent (Phase F). Embeddings for memory.recall: DEFAULT is the Vercel AI Gateway authed by
# VERCEL_OIDC_TOKEN (auto on Vercel; locally via `vercel env pull`) — no key needed. Set
# EMBED_API_KEY/OPENAI_API_KEY only to use OpenAI (or another provider via EMBED_BASE_URL) directly.
EMBED_API_KEY=
# eve channel auth: Clerk OIDC issuer + audience for the founders-only AuthFn (agent/channels/eve.ts).
# Tokens come from the "eve" JWT template (claims: aud+email+role) — client uses getToken({template:"eve"}).
# Issuer: https://clerk.admin.swayzio.com (prod) / https://immune-primate-92.clerk.accounts.dev (dev). Audience: eve.
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=eve
# trigger_sync write tool: GitHub token (actions:write) to dispatch .github/workflows/os-sync.yml.
SYNC_DISPATCH_TOKEN=
SYNC_REPO=mylesfranklin/swayzio-admin-dashboard
